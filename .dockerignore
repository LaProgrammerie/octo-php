# =============================================================================
# Docker build context exclusions
# =============================================================================

.git
.kiro
.github
.idea
.vscode

# Dependencies (installed during build)
vendor/
packages/*/vendor/
skeleton/vendor/

# Dev/test artifacts
*.cache
.phpunit.cache
coverage/

# OS files
.DS_Store
Thumbs.db

# Docker files (avoid recursive COPY)
docker-compose.yml
docker-compose.override.yml

# Documentation (not needed in runtime image)
docs/
*.md
!README.md
