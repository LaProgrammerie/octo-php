{
    "name": "octo-php/runtime-pack",
    "description": "OpenSwoole runtime pack for the Async PHP Platform — prod-safe HTTP server with healthchecks, graceful shutdown, reload policy, and structured concurrency.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-openswoole": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "giorgiosironi/eris": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Octo\\RuntimePack\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Octo\\RuntimePack\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
